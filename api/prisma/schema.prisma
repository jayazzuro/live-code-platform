generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model code_sessions {
  session_id   String   @id @db.Uuid
  language     String
  source_code  String?
  status       String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  output       String?

  executions   executions[]
}

model executions {
  execution_id      String   @id @db.Uuid
  session_id        String?  @db.Uuid
  status            String?
  stdout            String?
  stderr            String?
  execution_time_ms Int?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  session code_sessions? @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
}